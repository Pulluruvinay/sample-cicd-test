{
  "family": "sample-app-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "sample-app",
      "image": "187740755562.dkr.ecr.eu-west-1.amazonaws.com/sample-cicd-test:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sample-app",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "executionRoleArn": "arn:aws:iam::187740755562:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::187740755562:role/ecsTaskExecutionRole"
}
